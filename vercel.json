{
  "redirects": [
    {
      "source": "/",
      "destination": "/secured",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/flent-renewals",
      "destination": "https://flent-renewals.vercel.app/flent-renewals"
    },
    {
      "source": "/flent-renewals/:path*",
      "destination": "https://flent-renewals.vercel.app/flent-renewals/:path*"
    }
  ]
}
