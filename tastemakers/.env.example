# PostHog (client — same project key as the main Next.js app: NEXT_PUBLIC_POSTHOG_KEY)
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://ph.flent.in

# HubSpot private app token (server-only — never VITE_*).
# Scopes: crm.objects.contacts.read + crm.objects.contacts.write
# Copy to .env.local and paste your real token there — do not commit real tokens.
HUBSPOT_PRIVATE_APP_ACCESS_TOKEN=

# Optional: HubSpot internal name of a multi-line text property for full application blob.
# Create this property on contacts first; omit to sync only standard fields (email, name, city).
# HUBSPOT_APPLICATION_DETAILS_PROPERTY=tastemaker_application_details

# Optional: single-select dropdown (or text/checkbox) on the contact — use the property INTERNAL NAME
# and each option's INTERNAL VALUE from HubSpot (Settings → Properties); it may match the label or be a slug.
# Social URLs from the apply form are also written to HubSpot contact properties:
# `affiliate__linkedin` (first link) and `afilliatesociallinks` (additional links, comma-separated).
# Note: `customer_type` is always set to "Affiliate Applicant" by the tastemaker application API (api/submit-application.ts).
# Use the vars below only for a different property (do not duplicate customer_type unless you remove that line in code).
# If contacts still show another option (e.g. Tenant Lead), check HubSpot workflows that set this property,
# and confirm HUBSPOT_APPLICANT_FLAG_VALUE matches the Affiliate Applicant option’s internal value exactly.
# If the option's internal value contains spaces, quote it (otherwise only the first word is read).
# HUBSPOT_APPLICANT_FLAG_PROPERTY=customer_type
# HUBSPOT_APPLICANT_FLAG_VALUE="Affiliate Applicant"

# Optional: full absolute https URL for og:image / twitter:image (build-time). If unset, the build uses:
# https://www.flent.in/tastemakers/images/Meta%20Image%202.png
# VITE_OG_IMAGE_URL=https://www.flent.in/tastemakers/images/Meta%20Image%202.png
